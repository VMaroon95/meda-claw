{
  "version": "1.0.0",
  "metadata": {
    "framework": "meda_claw",
    "focus": "High-Impact Governance"
  },
  "critical_paths": {
    "authentication": [
      "**/auth/**",
      "**/middleware/**",
      "**/identity/**",
      "**/*login*",
      "**/*session*"
    ],
    "database": [
      "**/migrations/**",
      "**/schema/**",
      "**/*models.py",
      "**/*.sql"
    ],
    "infrastructure": [
      "**/terraform/**",
      "**/k8s/**",
      "**/.github/workflows/**",
      "**/Dockerfile",
      "**/helm/**"
    ],
    "financial_gateways": [
      "**/payments/**",
      "**/stripe/**",
      "**/billing/**"
    ]
  },
  "high_risk_tokens": [
    "eval(",
    "os.system(",
    "subprocess.run(",
    "chmod",
    "GRANT ALL",
    "DROP TABLE",
    "password =",
    "api_key =",
    "secret ="
  ],
  "scoring_multipliers": {
    "auth_violation": 2.5,
    "db_schema_change": 2.0,
    "infra_mutation": 3.0,
    "unreviewed_ai_logic": 1.5
  }
}
